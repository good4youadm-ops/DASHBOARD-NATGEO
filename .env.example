# =============================================================================
# APP
# =============================================================================
NODE_ENV=development
PORT=3001

# =============================================================================
# SUPABASE
# =============================================================================
# URL do projeto Supabase (pública — pode ir no frontend)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co

# Chave anon (pública — pode ir no frontend)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key — NUNCA expor no frontend; apenas workers e API server-side
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# ORACLE
# =============================================================================
ORACLE_USER=seu_usuario
ORACLE_PASSWORD=sua_senha

# Easy Connect: 192.168.1.100:1521/ORCL  |  TNS alias: ORCL_PROD
ORACLE_CONNECT_STRING=192.168.1.100:1521/ORCL

ORACLE_POOL_MIN=2
ORACLE_POOL_MAX=10
ORACLE_POOL_INCREMENT=1
ORACLE_CONNECT_TIMEOUT=30000

# =============================================================================
# SINCRONIZAÇÃO
# =============================================================================
# UUID do tenant padrão (criado em 001_tenants_and_users.sql)
SYNC_DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# Nome do sistema de origem (aparece nos logs e sync_state)
SYNC_SOURCE_NAME=oracle_distribuidora

# Tamanho do lote para upsert em massa
SYNC_BATCH_SIZE=500

# Intervalo entre execuções do sync loop (em segundos); padrão 1800 = 30min
SYNC_INTERVAL_SECONDS=1800

# Se true, executa o sync sem gravar nada no banco (teste seguro)
DRY_RUN=false

# =============================================================================
# CORS
# =============================================================================
# Origens permitidas para a API (separadas por vírgula, ou * para tudo)
# Produção: https://seudominio.com
# Dev local: http://localhost:3001 ou *
CORS_ORIGIN=*

# =============================================================================
# LOGS
# =============================================================================
# debug | info | warn | error
LOG_LEVEL=info

# Arquivo de log da API (relativo ao WORKDIR do container)
LOG_FILE=logs/api.log

# =============================================================================
# SEGURANÇA
# =============================================================================
# Chave interna para rotas protegidas (gere com: openssl rand -hex 32)
API_SECRET_KEY=gere_uma_chave_aleatoria_aqui

# Chave para criptografia de dados sensíveis em integrações futuras
# openssl rand -hex 32
INTEGRATION_ENCRYPTION_KEY=gere_outra_chave_aleatoria_aqui
