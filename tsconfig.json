{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@/lib/*": ["src/lib/*"],
      "@/repositories/*": ["src/repositories/*"],
      "@/hooks/*": ["src/hooks/*"],
      "@/mocks/*": ["src/mocks/*"]
    }
  },
  "include": ["src/**/*", "workers/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/services/api.ts",
    "src/hooks/**/*"
  ]
}
